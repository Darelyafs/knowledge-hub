# ============================================
# 知识共享库 — 环境变量配置
# 复制此文件为 .env，填入真实值
# ============================================

# Supabase PostgreSQL 连接串
# Supabase 控制台 → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.xxx:password@db.xxx.supabase.co:5432/postgres

# Supabase Storage（PDF 文件存储）
# Supabase 控制台 → Settings → API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...

# Storage bucket 名称（默认 pdfs）
SUPABASE_BUCKET=pdfs

# Flask 密钥（生产环境请设置随机字符串）
SECRET_KEY=your-random-secret
