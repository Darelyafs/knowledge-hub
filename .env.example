# ============================================
# 知识共享库 — 环境变量配置
# 复制此文件为 .env，填入真实值
# ============================================

# Supabase PostgreSQL 连接串
# 在 Supabase 控制台 → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-xxx.pooler.supabase.com:6543/postgres

# Cloudflare R2
# 在 Cloudflare 控制台 → R2 → 创建存储桶 → 管理 API 令牌
R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=knowledge-hub-pdfs
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Flask 密钥（生产环境请设置随机值）
# SECRET_KEY=your-random-secret-key
